# ── Techno Store — переменные окружения ──────────────────────────────
# Скопируйте этот файл в .env.local и при необходимости отредактируйте:
#   cp .env.example .env.local

# Подключение к локальной базе Postgres.
# Можно оставить пустым — тогда при первом запуске откроется мастер, где данные
# подключения (хост, порт, база, пользователь, пароль) вводятся вручную и
# сохраняются сюда автоматически.
#
# Пример для docker-compose.yml из этого репозитория:
#   DATABASE_URL="postgres://techno:techno@localhost:5433/techno_store"
# Пример для OSPanel (модуль PostgreSQL, по умолчанию порт 5432):
#   DATABASE_URL="postgres://postgres:пароль@localhost:5432/techno_store"
DATABASE_URL=""

# Секрет для Better Auth (обязателен). Сгенерируйте свой:
#   openssl rand -base64 32
BETTER_AUTH_SECRET="replace-me-with-openssl-rand-base64-32"

# Базовый URL приложения для Better Auth (для локали оставьте как есть).
BETTER_AUTH_URL="http://localhost:3000"

# API-ключ Нова Пошти (необязательно).
# Если не указать здесь, используется ключ из настроек доставки в базе (seed).
# NOVA_POSHTA_API_KEY=""

# Секрет для защиты /api/cron/delivery-sync (обязателен для продакшена!).
# Без него этот эндпоинт отвечает БЕЗ авторизации любому, кто знает URL —
# такой запрос дёргает API Новой Почты (расходует лимит), пишет в базу и
# может разослать письма клиентам об изменении статуса доставки.
# Сгенерируйте свой: openssl rand -base64 32
# На Vercel также впишите то же значение в Project Settings → Environment
# Variables — тогда Vercel Cron сам подставит его в заголовок Authorization.
CRON_SECRET="replace-me-with-openssl-rand-base64-32"

# Секрет для сайдкара автообновления (обязателен, чтобы кнопка «Обновить» на
# странице /admin/updates работала; без него страница просто показывает
# текущую/последнюю версию без возможности обновить одним кликом).
# Сгенерируйте свой: openssl rand -base64 32
# UPDATER_SECRET=""

# ── Пул соединений с БД (необязательно) ──────────────────────────────
# Настройки под высокую нагрузку. Значения по умолчанию подходят большинству
# случаев; увеличьте DB_POOL_MAX, если ждёте много одновременных посетителей и
# ваш Postgres/пулер позволяет больше соединений.
# DB_POOL_MAX="20"           # макс. соединений в пуле этого инстанса
# DB_POOL_IDLE_MS="30000"    # через сколько мс закрывать простаивающее соединение
# DB_POOL_CONNECT_MS="10000" # сколько мс ждать свободное соединение под нагрузкой
# DB_POOL_MAX_USES="7500"    # пересоздавать соединение после N запросов

# Фото товаров в админке по умолчанию сохраняются локально (public/uploads) —
# ничего указывать не нужно для Docker. Задайте эту переменную только если
# деплоите на Vercel и хотите хранить фото в Vercel Blob вместо диска:
# BLOB_READ_WRITE_TOKEN=""

# ── Мониторинг ошибок Sentry (необязательно, но рекомендуется на проде) ──
# Без этих переменных Sentry просто ничего не отправляет (безопасный no-op) —
# приложение работает как обычно. Чтобы включить:
#   1. Зарегистрируйтесь на sentry.io (бесплатного тарифа хватает для старта)
#   2. Создайте проект (платформа: Next.js), скопируйте DSN
#   3. Впишите его в обе переменные ниже (для одного проекта DSN одинаковый)
# SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"
# NEXT_PUBLIC_SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"
# Только для CI/сборки с загрузкой sourcemaps (необязательно):
# SENTRY_ORG=""
# SENTRY_PROJECT=""
# SENTRY_AUTH_TOKEN=""
